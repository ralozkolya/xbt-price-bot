NODE_ENV=
TG_TOKEN=
# Optional. If set, also re-register the webhook with Telegram's `secret_token`
# so the bot validates the X-Telegram-Bot-Api-Secret-Token header.
TG_WEBHOOK_SECRET=
WEBHOOK=
PORT=
DEBOUNCE_TIME=
DB_PATH=
# Change-alert trailing average. All three are in milliseconds.
#   CHANGE_WINDOW_MS  — lookback for the trailing mean (default 86400000 = 24h).
#   CHANGE_FLOOR_MS   — minimum observation time before any alert may fire
#                       after a fresh start (default 3600000 = 1h).
#   CHANGE_BUCKET_MS  — sample-folding bucket width (default 60000 = 1m).
# Must be positive integers; CHANGE_WINDOW_MS must exceed CHANGE_BUCKET_MS.
CHANGE_WINDOW_MS=
CHANGE_FLOOR_MS=
CHANGE_BUCKET_MS=
